{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "chess-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-27",
  "durable_objects": {
    "bindings": [
      {
        "name": "CHESS_GAME",
        "class_name": "ChessGame"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChessGame"]
    }
  ]
}
